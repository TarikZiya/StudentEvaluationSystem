{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "default_agent": "orchestrator",
  "instructions": [
    "docs/AGENTS.md"
  ],
  "lsp": true,
  "share": "manual",
  "snapshot": true,
  "tool_output": {
    "max_lines": 1000,
    "max_bytes": 32768
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 8
  },
  "permission": {
    "external_directory": {
      "*": "ask"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "npm run lint*": "allow",
      "npm run test*": "allow",
      "uv run ruff check*": "allow",
      "uv run pytest*": "allow"
    }
  }
}
